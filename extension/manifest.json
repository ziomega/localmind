{
  "manifest_version": 3,
  "name": "Local Mind",
  "version": "1.0.0",
  "description": "Your private, agentic browser memory layer.",

  "permissions": [
    "bookmarks",
    "history",
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "sidePanel",
    "windows"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],

  "chrome_url_overrides": {
    "newtab": "dashboard.html"
  },

  "commands": {
    "open-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Open Local Mind memory sidebar"
    }
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' http://127.0.0.1:8000 http://localhost:8000"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "Open Local Mind",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.bing.com/search*",
        "https://duckduckgo.com/*",
        "https://search.brave.com/search*"
      ],
      "js": ["search-trigger.js"],
      "run_at": "document_end"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["injected-panel.html", "injected-panel.js"],
      "matches": [
        "https://www.google.com/*",
        "https://www.bing.com/*",
        "https://duckduckgo.com/*",
        "https://search.brave.com/*"
      ]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}